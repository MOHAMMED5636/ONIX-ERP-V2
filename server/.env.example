# Use the same JWT_SECRET as your main ONIX auth API so Bearer tokens validate.
JWT_SECRET=change-me-to-match-main-backend

# Standalone server port (merge these routes into main API on 3001 in production).
PORT=3010

# Local demo only: decode JWT payload without verification (never use in production).
# POLICY_DEV_INSECURE=1

# --- Frontend (.env in ONIX-ERP-V2 root) ---
# Dev uses /api + setupProxy → this server on 3010 by default.
# To call a different URL from npm start: REACT_APP_POLICIES_USE_DIRECT=1 and REACT_APP_POLICIES_API_URL=...
